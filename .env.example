# PostgreSQL (UTC recommended)
# With docker-compose in this repo, Postgres is mapped to host port 5434 (see docker-compose.yml).
# If that port is busy too, edit docker-compose.yml and set DATABASE_URL to match.
# If you use a local Postgres instead of Docker, point DATABASE_URL at it (often port 5432).
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/medflow?schema=public"

JWT_SECRET="replace-with-long-random-string-min-32-chars"
# Token lifetime in seconds (default 604800 = 7 days)
JWT_EXPIRES_SEC=604800
# Access list of allowed phones. Name + gender live in the FamilyMember table
# (set at registration), so plain numbers are fine here. You MAY optionally add
# :name:gender to bootstrap a row, but bare phones never overwrite table names.
# ALLOWED_PHONE_NUMBERS=972521234567,972529876543,972528080147
# Optional bootstrap form: ALLOWED_PHONE_NUMBERS=972521234567:סתיו:female,972529876543:אבא:male
# Comma-separated browser origins allowed to call the API (e.g. your deployed SPA). Local dev defaults stay enabled without this.
# CORS_ORIGINS=https://your-spa.vercel.app,https://your-spa.pages.dev

# OpenAI-compatible API (Stage 3 — extraction + grounded Q&A)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Optional — single-patient label for AI prompts (Hebrew), default implies father
# PATIENT_NAME=
# When this phone messages on WhatsApp, replies use second person (אתה/לך/אותך). Required for dad second-person mode.
# PATIENT_PHONE=972529876543

# Meta WhatsApp Cloud API (Stage 4)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Family uses private 1:1 messages with wake word חנטריש (see summaries/stage-4-whatsapp-module.md).
# Optional: approved Meta authentication/utility template for OTP (works without 24h user message).
# Create in Meta → WhatsApp → Message templates (e.g. authentication with {{1}} = code).
# WHATSAPP_OTP_TEMPLATE_NAME=medflow_reset_code
# WHATSAPP_OTP_TEMPLATE_LANG=he
