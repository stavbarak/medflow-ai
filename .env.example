# PostgreSQL (UTC recommended)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/medflow?schema=public"

JWT_SECRET="replace-with-long-random-string-min-32-chars"
# Token lifetime in seconds (default 604800 = 7 days)
JWT_EXPIRES_SEC=604800
PORT=3000

# OpenAI-compatible API (Stage 3 — extraction + grounded Q&A)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Optional — single-patient label for AI prompts (Hebrew), default implies father
# PATIENT_NAME=

# Meta WhatsApp Cloud API (Stage 4)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
